# =============================================================================
# Docling-Graph ALP Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- AWS / Bedrock ---
AWS_PROFILE=mabrigos           # AWS CLI named profile to use
AWS_REGION_NAME=eu-west-1
# AWS_ROLE_ARN=              # Only needed for cross-account role assumption

# --- LLM Provider & Model ---
LLM_PROVIDER=bedrock
LLM_MODEL_ID=eu.anthropic.claude-sonnet-4-6

# --- LLM Generation Parameters ---
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=32000
# LLM_TOP_P=                 # Top-p sampling (0.0-1.0)
# LLM_TIMEOUT=120            # Request timeout in seconds
# LLM_MAX_RETRIES=3          # Max retry attempts on failure

# --- Chunking ---
CHUNK_MAX_TOKENS=512

# --- Pipeline Defaults ---
# PROCESSING_MODE=many-to-one    # one-to-one | many-to-one
# EXTRACTION_CONTRACT=direct     # direct | staged | delta
# STRUCTURED_OUTPUT=true         # Enable schema-enforced LLM output
